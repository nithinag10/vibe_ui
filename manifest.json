{
  "manifest_version": 3,
  "name": "Vibe",
  "version": "1.0",
  "description": "Customize any webpage with natural language. Powered by Claude.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>", "https://api.anthropic.com/*"],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vibe — AI page customizer",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
